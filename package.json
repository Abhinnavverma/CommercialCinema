{
  "name": "commerical-cinema",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "bun run --filter @commerical-cinema/gateway dev",
    "dev:user": "bun run --filter @commerical-cinema/user-service dev",
    "dev:cart": "bun run --filter @commerical-cinema/cart-service dev",
    "dev:menu": "bun run --filter @commerical-cinema/menu-service dev",
    "dev:stock": "bun run --filter @commerical-cinema/stock-service dev",
    "dev:order": "bun run --filter @commerical-cinema/order-service dev",
    "dev:analytics": "bun run --filter @commerical-cinema/analytics-service dev",
    "dev:notification": "bun run --filter @commerical-cinema/notification-service dev",
    "dev:twin": "bun run --filter @commerical-cinema/digital-twin dev",
    "dev:web": "bun run --filter @commerical-cinema/web dev",
    "dev:stack": "bun run scripts/dev-stack.ts",
    "start": "bun run scripts/start.ts",
    "start:gateway": "bun run --filter @commerical-cinema/gateway start",
    "start:user": "bun run --filter @commerical-cinema/user-service start",
    "start:cart": "bun run --filter @commerical-cinema/cart-service start",
    "start:menu": "bun run --filter @commerical-cinema/menu-service start",
    "start:stock": "bun run --filter @commerical-cinema/stock-service start",
    "start:order": "bun run --filter @commerical-cinema/order-service start",
    "start:analytics": "bun run --filter @commerical-cinema/analytics-service start",
    "start:notification": "bun run --filter @commerical-cinema/notification-service start",
    "start:twin": "bun run --filter @commerical-cinema/digital-twin start",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:generate": "bun run --filter @commerical-cinema/schema db:generate",
    "db:migrate": "bun run --filter @commerical-cinema/schema db:migrate",
    "db:seed": "bun run --filter @commerical-cinema/schema db:seed",
    "seed:redis": "bun run --filter @commerical-cinema/stock-service seed:redis",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter @commerical-cinema/cart-service test && bun run --filter @commerical-cinema/stock-service test && bun run --filter @commerical-cinema/order-service test && bun run --filter @commerical-cinema/menu-service test && bun run --filter @commerical-cinema/analytics-service test && bun run --filter @commerical-cinema/notification-service test && bun run --filter @commerical-cinema/digital-twin test && bun run --filter @commerical-cinema/web test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "ioredis": "5.10.1"
  }
}
